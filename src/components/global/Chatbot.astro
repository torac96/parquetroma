---
import { SITE_CONFIG } from '../../data/config';
// Strip trailing slash so data-siteurl is always "https://domain.com"
const siteUrl = SITE_CONFIG.url.replace(/\/$/, '');
---

<button
  id="chatbot-toggle"
  class="chatbot__toggle"
  aria-label="Apri chat di assistenza"
  aria-expanded="false"
  aria-controls="chatbot-panel"
>
  <svg class="chatbot__icon chatbot__icon--chat" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
  </svg>
  <svg class="chatbot__icon chatbot__icon--close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <path d="M18 6L6 18M6 6l12 12"/>
  </svg>
  <span class="chatbot__badge" aria-hidden="true">1</span>
</button>

<div
  id="chatbot-panel"
  class="chatbot__panel"
  role="dialog"
  aria-label="Chat assistenza ParquetRoma"
  aria-hidden="true"
  data-siteurl={siteUrl}
>
  <!-- Header -->
  <div class="chatbot__header">
    <div class="chatbot__avatar" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M12 2C8 2 5 5 5 9c0 2.4 1.1 4.5 2.8 5.9L7 20l4.5-2.1c.2 0 .3.1.5.1 3.9 0 7-3.1 7-7S15.9 2 12 2z"/>
      </svg>
    </div>
    <div class="chatbot__header-info">
      <p class="chatbot__name">{SITE_CONFIG.name}</p>
      <p class="chatbot__status">
        <span class="chatbot__dot" aria-hidden="true"></span>
        <span id="chatbot-status-text">Online · risponde subito</span>
      </p>
    </div>
    <button id="chatbot-close" class="chatbot__close" aria-label="Chiudi chat">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div id="chatbot-messages" class="chatbot__messages" role="log" aria-live="polite" aria-atomic="false">
  </div>

  <!-- Quick replies (shown only before first user message) -->
  <div id="chatbot-quickreplies" class="chatbot__quickreplies">
    <button class="chatbot__chip" data-msg="Come funziona il preventivo gratuito?">Preventivo gratuito</button>
    <button class="chatbot__chip" data-msg="In quali zone di Roma operate?">Zone coperte</button>
    <button class="chatbot__chip" data-msg="Quali tipi di parquet installate?">Tipi di parquet</button>
    <button class="chatbot__chip" data-msg="Quanto tempo ci vuole per la posa?">Tempi di posa</button>
  </div>

  <!-- Footer -->
  <div class="chatbot__footer">
    <input
      id="chatbot-input"
      type="text"
      class="chatbot__input"
      placeholder="Scrivi un messaggio…"
      maxlength="500"
      autocomplete="off"
    />
    <button id="chatbot-send" class="chatbot__send" aria-label="Invia messaggio">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
      </svg>
    </button>
  </div>
</div>

<script>
  import { initChatbot } from '../../scripts/ui/chatbot';
  document.addEventListener('astro:page-load', initChatbot);
</script>

<style is:global>
/* ── Toggle ─────────────────────────────────────────────── */
.chatbot__toggle {
  position: fixed;
  bottom: calc(80px + 1rem);
  right: 1rem;
  z-index: var(--z-modal);
  width: 54px;
  height: 54px;
  border-radius: var(--radius-full);
  background: var(--color-gold);
  color: #fff;
  box-shadow: var(--shadow-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--duration-200) var(--ease-spring), background var(--duration-150), box-shadow var(--duration-200);
}
.chatbot__toggle:hover {
  background: var(--color-gold-dark);
  transform: scale(1.1);
  box-shadow: 0 12px 40px rgba(196,146,42,.45);
}
.chatbot__toggle:active { transform: scale(0.93); }

.chatbot__icon--close { display: none; }
.chatbot__toggle[aria-expanded="true"] .chatbot__icon--chat  { display: none; }
.chatbot__toggle[aria-expanded="true"] .chatbot__icon--close { display: block; }

.chatbot__badge {
  position: absolute;
  top: -3px;
  right: -3px;
  width: 20px;
  height: 20px;
  border-radius: var(--radius-full);
  background: #e53e3e;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  line-height: 20px;
  text-align: center;
  border: 2px solid var(--color-surface);
  animation: badgePop var(--duration-300) var(--ease-spring) both;
}
.chatbot__toggle[aria-expanded="true"] .chatbot__badge { display: none; }

/* ── Panel ───────────────────────────────────────────────── */
.chatbot__panel {
  position: fixed;
  bottom: calc(80px + 1rem + 54px + 0.75rem);
  right: 1rem;
  z-index: var(--z-modal);
  width: min(370px, calc(100vw - 2rem));
  height: min(520px, calc(100vh - 200px));
  background: var(--color-card-bg);
  border: 1px solid var(--color-border-ui);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-xl);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  opacity: 0;
  transform: translateY(16px) scale(0.96);
  pointer-events: none;
  transition:
    opacity var(--duration-200) var(--ease-out),
    transform var(--duration-200) var(--ease-out);
}
.chatbot__panel--open {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
}

/* ── Header ──────────────────────────────────────────────── */
.chatbot__header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1rem;
  background: linear-gradient(135deg, var(--color-green) 0%, var(--color-green-light) 100%);
  color: #fff;
  flex-shrink: 0;
}
.chatbot__avatar {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.18);
  border: 1.5px solid rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.chatbot__header-info { flex: 1; min-width: 0; }
.chatbot__name { font-size: 0.9rem; font-weight: 700; line-height: 1.2; }
.chatbot__status {
  font-size: 0.7rem;
  opacity: 0.85;
  display: flex;
  align-items: center;
  gap: 0.35rem;
  margin-top: 2px;
}
.chatbot__dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--color-wa-green);
  flex-shrink: 0;
  animation: dotPulse 2s ease-in-out infinite;
}
.chatbot__close {
  color: rgba(255,255,255,0.65);
  padding: 0.3rem;
  border-radius: var(--radius-sm);
  transition: color var(--duration-150), background var(--duration-150);
  flex-shrink: 0;
}
.chatbot__close:hover { color: #fff; background: rgba(255,255,255,0.12); }

/* ── Messages ────────────────────────────────────────────── */
.chatbot__messages {
  flex: 1;
  overflow-y: auto;
  padding: 1rem 1rem 0.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  scroll-behavior: smooth;
}
.chatbot__messages::-webkit-scrollbar { width: 3px; }
.chatbot__messages::-webkit-scrollbar-track { background: transparent; }
.chatbot__messages::-webkit-scrollbar-thumb { background: var(--color-border-ui); border-radius: 3px; }

/* Date separator */
.chatbot__separator {
  text-align: center;
  font-size: 0.68rem;
  color: var(--color-text-muted);
  margin: 0.25rem 0;
  letter-spacing: 0.03em;
}

.chatbot__msg {
  max-width: 82%;
  padding: 0.6rem 0.875rem;
  border-radius: 18px;
  font-size: 0.845rem;
  line-height: 1.55;
  word-break: break-word;
  animation: msgIn var(--duration-200) var(--ease-out) both;
  position: relative;
}
/* User bubble: gold, right-aligned, tail bottom-right */
.chatbot__msg--user {
  align-self: flex-end;
  background: var(--color-gold);
  color: #fff;
  border-bottom-right-radius: 4px;
  box-shadow: 0 2px 8px rgba(196,146,42,.25);
}
/* Bot bubble: light card, left-aligned, tail bottom-left */
.chatbot__msg--model {
  align-self: flex-start;
  background: var(--color-surface-alt);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border-ui);
  border-bottom-left-radius: 4px;
}
.chatbot__msg--model strong { font-weight: 600; }
.chatbot__msg--model ul { padding-left: 1.1rem; margin: 0.3rem 0; }
.chatbot__msg--model li { margin: 0.15rem 0; }

/* Generic links in bot messages */
.chatbot__msg--model a {
  color: var(--color-gold-dark);
  text-decoration: underline;
}

/* Action buttons: phone, WhatsApp, email */
.chatbot__msg--model a[href^="tel:"],
.chatbot__msg--model a[href*="wa.me"],
.chatbot__msg--model a[href^="mailto:"] {
  display: inline-block;
  margin: 0.25rem 0.15rem 0 0;
  padding: 0.3rem 0.75rem;
  border-radius: var(--radius-full);
  font-weight: 700;
  font-size: 0.78rem;
  text-decoration: none;
  line-height: 1.5;
  letter-spacing: 0.01em;
  transition: filter var(--duration-150), transform var(--duration-100);
  vertical-align: middle;
}
.chatbot__msg--model a[href^="tel:"]:hover,
.chatbot__msg--model a[href*="wa.me"]:hover,
.chatbot__msg--model a[href^="mailto:"]:hover {
  filter: brightness(1.1);
  transform: translateY(-1px);
}

.chatbot__msg--model a[href^="tel:"] {
  background: #00897b;
  color: #fff;
}
.chatbot__msg--model a[href^="tel:"]::before { content: "☎ "; }

.chatbot__msg--model a[href*="wa.me"] {
  background: #25d366;
  color: #fff;
}
.chatbot__msg--model a[href*="wa.me"]::before { content: "💬 "; }

.chatbot__msg--model a[href^="mailto:"] {
  background: var(--color-gold);
  color: #fff;
}
.chatbot__msg--model a[href^="mailto:"]::before { content: "✉ "; }


/* Streaming cursor */
.chatbot__msg--streaming::after {
  content: '';
  display: inline-block;
  width: 2px;
  height: 0.9em;
  background: var(--color-gold);
  margin-left: 2px;
  vertical-align: text-bottom;
  animation: cursorBlink 0.7s step-end infinite;
}

/* Typing indicator */
.chatbot__msg--typing {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 0.75rem 1rem;
  background: var(--color-surface-alt);
  border-radius: var(--radius-lg);
  border-bottom-left-radius: 4px;
  align-self: flex-start;
  animation: msgIn var(--duration-200) var(--ease-out) both;
}
.chatbot__msg--typing span {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--color-text-muted);
  animation: typingBounce 1.2s ease-in-out infinite;
}
.chatbot__msg--typing span:nth-child(2) { animation-delay: 0.2s; }
.chatbot__msg--typing span:nth-child(3) { animation-delay: 0.4s; }

/* ── Quick replies ───────────────────────────────────────── */
.chatbot__quickreplies {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  padding: 0.5rem 1rem 0.625rem;
  flex-shrink: 0;
}
.chatbot__quickreplies.hidden { display: none; }
.chatbot__chip {
  padding: 0.3rem 0.7rem;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border-ui);
  background: var(--color-surface-alt);
  color: var(--color-text-secondary);
  font-size: 0.75rem;
  font-weight: 500;
  cursor: pointer;
  transition: border-color var(--duration-150), background var(--duration-150), color var(--duration-150);
  white-space: nowrap;
}
.chatbot__chip:hover {
  border-color: var(--color-gold);
  background: var(--color-gold-pale);
  color: var(--color-gold-dark);
}

/* ── Footer ──────────────────────────────────────────────── */
.chatbot__footer {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.625rem 0.875rem 0.75rem;
  border-top: 1px solid var(--color-border-ui);
  flex-shrink: 0;
}
.chatbot__input {
  flex: 1;
  padding: 0.55rem 0.875rem;
  border-radius: var(--radius-full);
  border: 1.5px solid var(--color-border-ui);
  background: var(--color-surface-alt);
  color: var(--color-text-primary);
  font-size: 0.875rem;
  outline: none;
  transition: border-color var(--duration-150), box-shadow var(--duration-150);
}
.chatbot__input:focus {
  border-color: var(--color-gold);
  box-shadow: 0 0 0 3px rgba(196,146,42,.12);
}
.chatbot__input::placeholder { color: var(--color-text-muted); }
.chatbot__input:disabled { opacity: 0.5; }

.chatbot__send {
  width: 38px;
  height: 38px;
  border-radius: var(--radius-full);
  background: var(--color-gold);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background var(--duration-150), transform var(--duration-100), box-shadow var(--duration-150);
}
.chatbot__send:hover { background: var(--color-gold-dark); box-shadow: 0 4px 12px rgba(196,146,42,.35); }
.chatbot__send:active { transform: scale(0.9); }
.chatbot__send:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

/* Loading spinner inside send button */
.chatbot__send--loading svg { display: none; }
.chatbot__send--loading::after {
  content: '';
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255,255,255,0.35);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

/* ── Animations ──────────────────────────────────────────── */
@keyframes msgIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: .5; }
  30%            { transform: translateY(-6px); opacity: 1; }
}
@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}
@keyframes dotPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(37,211,102,0.5); }
  50%       { box-shadow: 0 0 0 4px rgba(37,211,102,0); }
}
@keyframes badgePop {
  0%   { transform: scale(0); opacity: 0; }
  70%  { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── Mobile ──────────────────────────────────────────────── */
@media (max-width: 420px) {
  .chatbot__panel { right: 0.5rem; width: calc(100vw - 1rem); }
  .chatbot__toggle { right: 0.5rem; }
}
</style>
