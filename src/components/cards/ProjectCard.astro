---
import type { Project } from '../../data/portfolio';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const sliderId = `slider-${project.id}`;
---

<article class="project-card" data-category={project.category} aria-labelledby={`p-${project.id}`}>
  <div
    class="ba-slider"
    data-slider
    aria-label={`Prima e dopo — ${project.title}`}
    id={sliderId}
  >
    <div class="ba-after">
      <img
        src={project.after}
        alt={`${project.wood} ${project.title} Roma — dopo`}
        width="900"
        height="600"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="ba-before">
      <img
        src={project.before}
        alt={`Prima — ${project.title}`}
        width="900"
        height="600"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="ba-handle" aria-hidden="true">
      <div class="ba-handle-line"></div>
      <div class="ba-handle-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </div>
      <div class="ba-handle-line"></div>
    </div>
    <span class="ba-label ba-label--before" aria-hidden="true">Prima</span>
    <span class="ba-label ba-label--after" aria-hidden="true">Dopo</span>
  </div>

  <div class="project-card__body">
    <div class="project-card__tags">
      {project.tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
    <h3 class="project-card__title" id={`p-${project.id}`}>{project.title}</h3>
    <p class="project-card__desc">{project.desc}</p>
    <blockquote class="project-card__quote">"{project.quote}"</blockquote>
  </div>
</article>

<style>
.project-card {
  background: var(--color-card-bg);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--color-border-ui);
  transition: transform var(--duration-300) var(--ease-out), box-shadow var(--duration-300) var(--ease-out);
}
.project-card:hover {
  transform: translateY(var(--card-lift));
  box-shadow: var(--shadow-lg);
}

/* Before/After slider */
.ba-slider {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/2;
  cursor: ew-resize;
  user-select: none;
  touch-action: pan-y;
}
.ba-after,
.ba-before {
  position: absolute;
  inset: 0;
}
.ba-after { z-index: 1; }
.ba-before {
  z-index: 2;
  width: 50%;
  overflow: hidden;
}
.ba-after img,
.ba-before img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
}
.ba-before img { width: calc(100vw); max-width: 900px; }
.ba-handle {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  z-index: 3;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}
.ba-handle-line {
  flex: 1;
  width: 2px;
  background: #fff;
  opacity: .8;
}
.ba-handle-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  box-shadow: 0 2px 12px rgba(0,0,0,.3);
  flex-shrink: 0;
  color: #1E1A15;
}
.ba-label {
  position: absolute;
  bottom: 1rem;
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: var(--ls-wider);
  text-transform: uppercase;
  background: rgba(0,0,0,.45);
  color: #fff;
  padding: .25rem .6rem;
  border-radius: var(--radius-sm);
  z-index: 4;
  backdrop-filter: blur(4px);
}
.ba-label--before { left: 1rem; }
.ba-label--after  { right: 1rem; }

/* Card body */
.project-card__body { padding: 1.5rem; }
.project-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: .4rem;
  margin-bottom: .9rem;
}
.project-card__title {
  font-family: var(--font-serif);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-on-surface);
  margin-bottom: .6rem;
}
.project-card__desc {
  font-size: .875rem;
  color: var(--color-text-secondary);
  line-height: var(--lh-relaxed);
  margin-bottom: 1rem;
}
.project-card__quote {
  font-size: .82rem;
  color: var(--color-text-muted);
  border-left: 2px solid var(--color-gold);
  padding-left: .75rem;
  line-height: var(--lh-relaxed);
  font-style: italic;
}
</style>
