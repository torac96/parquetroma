---
const stats = [
  { count: 20,  suffix: '+', label: 'Anni di Esperienza' },
  { count: 500, suffix: '+', label: 'Progetti Realizzati' },
  { count: 127, suffix: '',  label: 'Recensioni 5 Stelle' },
  { count: 100, suffix: '%', label: 'Soddisfazione Garantita' },
];
---

<section class="trust-bar" aria-label="Le nostre statistiche">
  <div class="container trust-bar__inner">
    {stats.map((s, i) => (
      <>
        <div class="trust-bar__stat">
          <span
            class="trust-bar__number"
            data-count={s.count}
            data-suffix={s.suffix}
          >{s.count}{s.suffix}</span>
          <span class="trust-bar__label">{s.label}</span>
        </div>
        {i < stats.length - 1 && <div class="trust-bar__divider" aria-hidden="true"></div>}
      </>
    ))}
  </div>
</section>

<style>
.trust-bar {
  background: var(--color-dark);
  padding-block: 3.5rem;
  border-top: 1px solid rgba(255,255,255,.06);
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.trust-bar__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2rem 0;
}
.trust-bar__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .4rem;
  padding-inline: clamp(2rem, 5vw, 4rem);
  text-align: center;
}
.trust-bar__number {
  font-family: var(--font-serif);
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  font-weight: 700;
  color: var(--color-gold-light);
  line-height: 1;
  will-change: contents;
}
.trust-bar__label {
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: var(--ls-wider);
  text-transform: uppercase;
  color: rgba(255,255,255,.45);
}
.trust-bar__divider {
  width: 1px;
  height: 3rem;
  background: rgba(255,255,255,.1);
  flex-shrink: 0;
}
@media (max-width: 640px) {
  .trust-bar__inner { gap: 2rem; }
  .trust-bar__divider { display: none; }
  .trust-bar__stat { padding-inline: 1.5rem; }
}
</style>
