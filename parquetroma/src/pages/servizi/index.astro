---
import PageLayout    from '../../layouts/PageLayout.astro';
import PageHero      from '../../components/sections/PageHero.astro';
import TrustBar      from '../../components/sections/TrustBar.astro';
import CtaBand       from '../../components/sections/CtaBand.astro';
import { url }       from '../../utils/url';

const breadcrumbs = [{ name: 'Servizi', url: '/servizi/' }];
---

<PageLayout
  title="Posa Parquet Roma | Levigatura, Restauro, Consulenza | ParquetRoma"
  description="Posa parquet Roma professionale: levigatura, restauro, installazione porte e consulenza design. 20+ anni di esperienza artigianale. Sopralluogo gratuito entro 48 ore."
  breadcrumbs={breadcrumbs}
  lcpImage="https://picsum.photos/seed/parquet-tools/1920/800"
>
  <PageHero
    eyebrow="Tutto Quello che Offriamo"
    title="Servizi Professionali<br><em>di Posa Parquet a Roma</em>"
    subtitle="Dalla consulenza iniziale alla consegna finale: un servizio completo che trasforma il tuo spazio con la maestria del legno."
    image="https://picsum.photos/seed/parquet-tools/1920/800"
    breadcrumbs={[{ name: 'Servizi', href: '' }]}
    actions={true}
  >
    <div slot="actions" style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem">
      <a href={url('/contatti/')} class="btn btn--primary btn--lg">Preventivo Gratuito</a>
      <a href="tel:+390612345678" class="btn btn--ghost btn--lg">Chiama Ora</a>
    </div>
  </PageHero>

  <!-- PARQUET -->
  <section class="section" id="parquet" aria-labelledby="svc1-title">
    <span class="section-num section-num--right" aria-hidden="true">01</span>
    <div class="container">
      <div class="service-detail reveal-up">
        <div class="service-detail__image clip-reveal">
          <img
            src="https://picsum.photos/seed/parquet-herringbone/900/675"
            alt="Posa parquet a spina di pesce Roma"
            width="900"
            height="675"
            loading="lazy" decoding="async"
          />
        </div>
        <div class="service-detail__content">
          <span class="service-detail__eyebrow">Servizio Principale</span>
          <h2 class="service-detail__title" id="svc1-title">Posa <em>Parquet</em><br>Professionale</h2>
          <p class="service-detail__desc">Installiamo pavimenti in legno pregiato con la precisione che solo 20+ anni di esperienza possono garantire. Ogni progetto inizia dall'ascolto: capiamo il tuo stile, il tuo spazio, e ti guidiamo verso la scelta perfetta.</p>
          <ul class="features-list" role="list">
            <li>Sopralluogo e consulenza gratuita</li>
            <li>Selezione essenze: quercia, noce, frassino, bambù, wengé, pino</li>
            <li>Pattern: spina di pesce, diagonale, dritto, mattoni, chevron</li>
            <li>Posa tradizionale incollata e posa flottante</li>
            <li>Preparazione e livellamento sottofondo</li>
            <li>Levigatura, verniciatura, oliatura e ceratura</li>
            <li>Garanzia scritta sul lavoro eseguito</li>
          </ul>
          <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <a href={url('/preventivo-parquet-roma/')} class="btn btn--primary btn--lg">Richiedi Preventivo</a>
            <a href={url('/posa-parquet-roma/')} class="btn btn--ghost">Scopri il servizio completo</a>
          </div>
        </div>
      </div>

      <!-- Essenze -->
      <div class="section__header reveal-up" style="margin-top:5rem">
        <p class="section__eyebrow">Le Nostre Essenze</p>
        <h3 class="section__title">Ogni Legno Racconta<br><em>una Storia Diversa</em></h3>
      </div>
      <div class="woods-grid stagger-grid">
        <div class="wood-swatch-card">
          <div class="wood-swatch wood-swatch--quercia"></div>
          <div class="wood-swatch-card__body">
            <p class="wood-swatch-card__name">Quercia</p>
            <p class="wood-swatch-card__desc">Classica, versatile, dalla venatura ricca. La scelta più amata.</p>
          </div>
        </div>
        <div class="wood-swatch-card">
          <div class="wood-swatch wood-swatch--noce"></div>
          <div class="wood-swatch-card__body">
            <p class="wood-swatch-card__name">Noce</p>
            <p class="wood-swatch-card__desc">Scuro, elegante, dall'atmosfera calda e sofisticata.</p>
          </div>
        </div>
        <div class="wood-swatch-card">
          <div class="wood-swatch wood-swatch--frassino"></div>
          <div class="wood-swatch-card__body">
            <p class="wood-swatch-card__name">Frassino</p>
            <p class="wood-swatch-card__desc">Chiaro, moderno, perfetto per ambienti luminosi e minimalisti.</p>
          </div>
        </div>
        <div class="wood-swatch-card">
          <div class="wood-swatch wood-swatch--bambu"></div>
          <div class="wood-swatch-card__body">
            <p class="wood-swatch-card__name">Bambù</p>
            <p class="wood-swatch-card__desc">Sostenibile, durissimo, dall'estetica contemporanea e originale.</p>
          </div>
        </div>
        <div class="wood-swatch-card">
          <div class="wood-swatch wood-swatch--wenge"></div>
          <div class="wood-swatch-card__body">
            <p class="wood-swatch-card__name">Wengé</p>
            <p class="wood-swatch-card__desc">Esotico, scurissimo, per ambienti di grande impatto visivo.</p>
          </div>
        </div>
        <div class="wood-swatch-card">
          <div class="wood-swatch wood-swatch--pino"></div>
          <div class="wood-swatch-card__body">
            <p class="wood-swatch-card__name">Pino Nordico</p>
            <p class="wood-swatch-card__desc">Rustico e caldo, con nodi caratteristici. Spirito nordico autentico.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTE -->
  <section class="section section--alt" id="porte" aria-labelledby="svc2-title">
    <span class="section-num section-num--left" aria-hidden="true">02</span>
    <div class="container">
      <div class="service-detail service-detail--reverse reveal-up">
        <div class="service-detail__content">
          <span class="service-detail__eyebrow">Servizio Complementare</span>
          <h2 class="service-detail__title" id="svc2-title">Installazione<br><em>Porte in Legno</em></h2>
          <p class="service-detail__desc">Un parquet straordinario merita porte all'altezza. Installiamo porte interne ed esterne in legno coordinate esteticamente con il pavimento scelto, per un risultato finale armonioso e di grande impatto.</p>
          <ul class="features-list" role="list">
            <li>Porte interne battente, scorrevoli a scomparsa, filomuro</li>
            <li>Porte blindate e di sicurezza</li>
            <li>Montaggio telaio e controtelaio</li>
            <li>Coordinamento cromatico ed estetico con il parquet</li>
            <li>Rifacimento di porte esistenti</li>
            <li>Consulenza su stile: classico, moderno, minimal</li>
          </ul>
          <a href={url('/contatti/')} class="btn btn--primary btn--lg">Prenota Consulenza</a>
        </div>
        <div class="service-detail__image clip-reveal">
          <img
            src="https://picsum.photos/seed/door-wood-detail/900/675"
            alt="Installazione porta in legno coordinata con parquet Roma"
            width="900"
            height="675"
            loading="lazy" decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CONSULENZA -->
  <section class="section" id="consulenza" aria-labelledby="svc3-title">
    <span class="section-num section-num--right" aria-hidden="true">03</span>
    <div class="container">
      <div class="service-detail reveal-up">
        <div class="service-detail__image clip-reveal">
          <img
            src="https://picsum.photos/seed/design-samples/900/675"
            alt="Consulenza design parquet Roma campionari essenze"
            width="900"
            height="675"
            loading="lazy" decoding="async"
          />
        </div>
        <div class="service-detail__content">
          <span class="service-detail__eyebrow">Servizio Gratuito</span>
          <h2 class="service-detail__title" id="svc3-title">Consulenza<br><em>&amp; Design</em></h2>
          <p class="service-detail__desc">Non sai da dove iniziare? È normale. Ventidue anni di progetti ci hanno insegnato che la scelta giusta del legno trasforma un appartamento ordinario in uno straordinario. Ti guidiamo passo dopo passo.</p>
          <ul class="features-list" role="list">
            <li>Sopralluogo gratuito a domicilio</li>
            <li>Analisi dello spazio, della luce e dello stile</li>
            <li>Presentazione campionari fisici a casa tua</li>
            <li>Simulazione visiva del risultato finale</li>
            <li>Pianificazione lavori e tempistiche</li>
            <li>Supporto nella scelta del pattern di posa</li>
          </ul>
          <a href={url('/contatti/')} class="btn btn--primary btn--lg">Prenota il Sopralluogo</a>
        </div>
      </div>
    </div>
  </section>

  <!-- LEVIGATURA -->
  <section class="section section--alt" id="levigatura" aria-labelledby="svc4-title">
    <span class="section-num section-num--left" aria-hidden="true">04</span>
    <div class="container">
      <div class="service-detail service-detail--reverse reveal-up">
        <div class="service-detail__content">
          <span class="service-detail__eyebrow">Restauro e Manutenzione</span>
          <h2 class="service-detail__title" id="svc4-title">Levigatura<br><em>&amp; Restauro Parquet</em></h2>
          <p class="service-detail__desc">Il tuo parquet esistente ha perso smalto? Non è necessario sostituirlo. Con levigatura professionale, verniciatura o oliatura, lo riportiamo alla bellezza originale — e spesso ancora meglio.</p>
          <ul class="features-list" role="list">
            <li>Levigatura a umido con macchinari professionali silenziosi</li>
            <li>Riparazione assi danneggiate o sollevate</li>
            <li>Trattamento antitarme e antimuffa</li>
            <li>Verniciatura opaca, satinata o lucida</li>
            <li>Oliatura e ceratura naturale</li>
            <li>Cambio di finitura (da lucido a opaco e viceversa)</li>
          </ul>
          <a href={url('/contatti/')} class="btn btn--primary btn--lg">Richiedi Valutazione</a>
        </div>
        <div class="service-detail__image clip-reveal">
          <img
            src="https://picsum.photos/seed/sanding-parquet/900/675"
            alt="Levigatura parquet professionale Roma restauro"
            width="900"
            height="675"
            loading="lazy" decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <TrustBar />

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <CtaBand
        title="Qual è il Tuo Progetto?"
        text="Raccontaci di cosa hai bisogno — sopralluogo gratuito entro 48 ore."
        formCta="Scrivi Online"
      />
    </div>
  </section>
</PageLayout>

<style>
.service-detail {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: center;
  margin-bottom: clamp(5rem, 10vw, 8rem);
  position: relative;
  z-index: 1;
}
.service-detail:last-child { margin-bottom: 0; }
.service-detail--reverse .service-detail__image { order: 2; }
.service-detail--reverse .service-detail__content { order: 1; }
.service-detail__image {
  border-radius: var(--radius-xl);
  overflow: hidden;
  aspect-ratio: 4/3;
}
.service-detail__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--duration-500) var(--ease-out);
}
.service-detail__image:hover img { transform: scale(1.04); }
.service-detail__eyebrow {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: .85rem;
  display: block;
}
.service-detail__title {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  font-weight: 700;
  color: var(--color-on-surface);
  line-height: 1.15;
  letter-spacing: -.02em;
  margin-bottom: 1rem;
}
.service-detail__title em { font-style: italic; color: var(--color-gold); }
.service-detail__desc {
  color: var(--color-text-secondary);
  margin-bottom: 1.75rem;
  line-height: 1.75;
  font-size: 1rem;
}
.features-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: .6rem;
  margin-bottom: 2rem;
}
.features-list li {
  display: flex;
  align-items: flex-start;
  gap: .75rem;
  font-size: .9rem;
  color: var(--color-text-secondary);
}
.features-list li::before {
  content: '';
  display: inline-block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--color-gold);
  flex-shrink: 0;
  margin-top: .45rem;
}

/* Wood swatches grid */
.woods-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 4rem;
}
.wood-swatch-card {
  background: var(--color-card-bg);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--color-border-ui);
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-250) var(--ease-out), box-shadow var(--duration-250);
}
.wood-swatch-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
.wood-swatch { height: 100px; }
.wood-swatch--quercia { background: linear-gradient(135deg, #C8923A, #A06820); }
.wood-swatch--noce    { background: linear-gradient(135deg, #6B3A1F, #4A2510); }
.wood-swatch--frassino{ background: linear-gradient(135deg, #B0A090, #8A7A6A); }
.wood-swatch--bambu   { background: linear-gradient(135deg, #7A8A50, #5A6A30); }
.wood-swatch--wenge   { background: linear-gradient(135deg, #2A1A0A, #1A0A00); }
.wood-swatch--pino    { background: linear-gradient(135deg, #D4C090, #B0A070); }
.wood-swatch-card__body { padding: 1.1rem; }
.wood-swatch-card__name {
  font-family: var(--font-serif);
  font-size: .95rem;
  font-weight: 700;
  color: var(--color-on-surface);
}
.wood-swatch-card__desc {
  font-size: .78rem;
  color: var(--color-text-secondary);
  margin-top: .2rem;
}

@media (max-width: 900px) {
  .service-detail { grid-template-columns: 1fr; }
  .service-detail--reverse .service-detail__image { order: 0; }
  .service-detail--reverse .service-detail__content { order: 0; }
  .woods-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
