---
import type { Material } from '../../data/materials';

interface Props {
  material: Material;
}
const { material } = Astro.props;
---

<a href={material.href} class="wood-card tilt-card" aria-label={`${material.name} — ${material.latin}`}>
  <div class="wood-card__img-wrap">
    <img
      src={material.bg}
      alt={`Parquet ${material.name} — ${material.latin}`}
      width="600"
      height="900"
      loading="lazy"
    />
    <div class="wood-card__overlay" aria-hidden="true"></div>
  </div>
  <div class="wood-card__body">
    <span class="wood-card__latin">{material.latin}</span>
    <h3 class="wood-card__name">{material.name}</h3>
    <p class="wood-card__desc">{material.description}</p>
    <span class="wood-card__link" aria-hidden="true">
      Scopri
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </span>
  </div>
</a>

<style>
.wood-card {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  min-height: 420px;
  cursor: pointer;
  transform-style: preserve-3d;
  backface-visibility: hidden;
}
.wood-card__img-wrap {
  position: absolute;
  inset: 0;
  overflow: hidden;
}
.wood-card__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--duration-700) var(--ease-out);
}
.wood-card:hover .wood-card__img-wrap img { transform: scale(1.06); }
.wood-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(0deg, rgba(0,0,0,.82) 0%, rgba(0,0,0,.2) 55%, transparent 100%);
}
.wood-card__body {
  position: relative;
  z-index: 1;
  margin-top: auto;
  padding: 1.75rem;
}
.wood-card__latin {
  font-size: .7rem;
  font-style: italic;
  color: rgba(255,255,255,.4);
  display: block;
  margin-bottom: .4rem;
  letter-spacing: .04em;
}
.wood-card__name {
  font-family: var(--font-serif);
  font-size: 1.6rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: .6rem;
  line-height: var(--lh-tight);
}
.wood-card__desc {
  font-size: .82rem;
  color: rgba(255,255,255,.65);
  line-height: var(--lh-relaxed);
  margin-bottom: 1rem;
}
.wood-card__link {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: var(--ls-wider);
  text-transform: uppercase;
  color: var(--color-gold-light);
  transition: gap var(--duration-200);
}
.wood-card:hover .wood-card__link { gap: .7rem; }
</style>
