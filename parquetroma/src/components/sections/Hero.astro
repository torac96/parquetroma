---
import { SITE_CONFIG } from '../../data/config';
import { url } from '../../utils/url';
---

<section class="hero" id="hero" aria-label="Sezione principale">
  <div class="hero__bg" aria-hidden="true">
    <img
      src="https://picsum.photos/seed/parquet-hero/1920/1080"
      alt=""
      class="hero__bg-img"
      width="1920"
      height="1080"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
    />
    <div class="hero__overlay"></div>
    <div class="hero__overlay-2"></div>
    <div class="hero__orb hero__orb--1" aria-hidden="true"></div>
    <div class="hero__orb hero__orb--2" aria-hidden="true"></div>
  </div>

  <div class="container hero__content">
    <div class="hero__brand-line" aria-hidden="true"></div>
    <span class="hero__eyebrow">Roma &amp; Lazio — Dal 2003</span>
    <h1 class="hero__title">Maestria Artigianale<br><em>nel Parquet</em></h1>
    <p class="hero__subtitle">20+ anni di esperienza trasformano il tuo spazio in un'opera d'arte. Installazione professionale di parquet e porte a Roma.</p>
    <div class="hero__actions">
      <a href={url('/contatti/')} class="btn btn--primary btn--lg">Richiedi Preventivo Gratuito</a>
      <a href={url('/portfolio/')} class="btn btn--ghost btn--lg">Vedi il Portfolio</a>
    </div>
    <div class="hero__badges" role="list">
      <div class="hero__badge" role="listitem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        <span><strong>20+</strong> Anni di Esperienza</span>
      </div>
      <div class="hero__badge" role="listitem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        <span><strong>500+</strong> Progetti</span>
      </div>
      <div class="hero__badge" role="listitem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span><strong>5.0</strong> Google Rating</span>
      </div>
      <div class="hero__badge" role="listitem">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <span><strong>Certificato</strong> Professionale</span>
      </div>
    </div>
  </div>

  <a href="#marquee" class="hero__scroll" aria-label="Scorri verso il basso">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </a>
</section>

<style>
.hero {
  position: relative;
  min-height: 100dvh;
  display: flex;
  align-items: flex-end;
  padding-top: var(--header-h);
  overflow: hidden;
}
.hero__bg { position: absolute; inset: 0; z-index: 0; }
.hero__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  will-change: transform;
}
.hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(170deg, rgba(16,10,2,.08) 0%, rgba(16,10,2,.55) 45%, rgba(16,10,2,.88) 100%);
}
.hero__overlay-2 { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(16,10,2,.6) 0%, transparent 70%); }
.hero__orb { position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none; will-change: transform; }
.hero__orb--1 { width: 500px; height: 500px; background: rgba(196,146,42,.12); top: -120px; right: -80px; }
.hero__orb--2 { width: 320px; height: 320px; background: rgba(45,80,22,.1); bottom: 60px; right: 20%; }
.hero__content {
  position: relative;
  z-index: 1;
  padding-block: clamp(3rem, 8vh, 5rem) clamp(4rem, 9vh, 7rem);
  max-width: 760px;
}
.hero__brand-line { width: 0; height: 1.5px; background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light)); margin-bottom: 1.25rem; border-radius: 1px; will-change: width; }
.hero__eyebrow { font-size: .78rem; font-weight: 700; letter-spacing: var(--ls-widest); text-transform: uppercase; color: var(--color-gold-light); margin-bottom: 1.5rem; display: block; opacity: 0; }
.hero__title { font-family: var(--font-serif); font-size: clamp(3rem, 8vw, 6.5rem); font-weight: 700; color: #fff; line-height: var(--lh-none); margin-bottom: 1.75rem; letter-spacing: var(--ls-tighter); }
.hero__subtitle { font-size: clamp(1.05rem, 1.8vw, 1.2rem); color: rgba(255,255,255,.8); max-width: 520px; margin-bottom: 2.5rem; line-height: var(--lh-relaxed); opacity: 0; }
.hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3.5rem; opacity: 0; }
.hero__badges { display: flex; gap: 2rem; flex-wrap: wrap; }
.hero__badge { display: flex; align-items: center; gap: .6rem; font-size: .82rem; color: rgba(255,255,255,.85); opacity: 0; transform: translateY(10px); }
.hero__badge svg { color: var(--color-gold-light); flex-shrink: 0; }
.hero__badge strong { color: #fff; font-weight: 700; }
.hero__scroll {
  position: absolute;
  bottom: 2.5rem; right: 2.5rem;
  z-index: 1;
  width: 52px; height: 52px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,.3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  backdrop-filter: blur(6px);
  transition: border-color var(--duration-200), background var(--duration-200);
}
.hero__scroll:hover { border-color: var(--color-gold); background: rgba(196,146,42,.15); }
@media (max-width: 768px) {
  .hero__scroll { bottom: 1.5rem; right: 1.5rem; }
  .hero__title { font-size: clamp(2.5rem, 9vw, 3rem); }
}
</style>
