<div class="marquee" id="marquee" aria-hidden="true">
  <div class="marquee__inner">
    <span class="marquee__item"><strong>20+</strong> anni di esperienza <span class="marquee__dot"></span></span>
    <span class="marquee__item"><strong>500+</strong> progetti realizzati <span class="marquee__dot"></span></span>
