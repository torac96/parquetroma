---
---

<section class="statement-section" aria-label="La nostra filosofia">
  <div class="statement__wm" aria-hidden="true">MAESTRIA</div>
  <div class="container statement__inner">
    <div class="statement__decorator" aria-hidden="true"></div>
    <blockquote class="statement__quote">
      <span class="statement__line"><span class="statement__line-inner">Dal 2003, trasformiamo</span></span>
      <span class="statement__line"><span class="statement__line-inner"><em>spazi in emozioni.</em></span></span>
      <span class="statement__line"><span class="statement__line-inner">Progetto dopo progetto.</span></span>
    </blockquote>
    <div class="statement__meta">
      <span>ParquetRoma — Roma</span>
      <div class="statement__meta-sep" aria-hidden="true"></div>
      <span>500+ famiglie soddisfatte</span>
      <div class="statement__meta-sep" aria-hidden="true"></div>
      <span>Dal 2003</span>
    </div>
  </div>
  <div class="statement__ticker" aria-hidden="true">
    <div class="statement__ticker-inner">
      <span>Qualità Artigianale <span class="marquee__dot"></span></span>
      <span>500+ Famiglie Felici <span class="marquee__dot"></span></span>
      <span>Roma &amp; Lazio <span class="marquee__dot"></span></span>
      <span>Dal 2003 <span class="marquee__dot"></span></span>
      <span>Eccellenza nel Parquet <span class="marquee__dot"></span></span>
      <span>Garanzia Scritta <span class="marquee__dot"></span></span>
      <span>Sopralluogo Gratuito <span class="marquee__dot"></span></span>
      <span>20+ Anni di Esperienza <span class="marquee__dot"></span></span>
    </div>
  </div>
</section>

<style>
.statement-section {
  position: relative;
  background: var(--color-dark);
  overflow: hidden;
  padding-block: clamp(5rem, 12vh, 9rem);
}
.statement__wm {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-serif);
  font-size: clamp(8rem, 22vw, 20rem);
  font-weight: 700;
  color: rgba(255,255,255,.028);
  letter-spacing: var(--ls-tighter);
  pointer-events: none;
  user-select: none;
  white-space: nowrap;
  line-height: 1;
}
.statement__inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.statement__decorator {
  width: 1.5px;
  height: 4rem;
  background: linear-gradient(180deg, transparent, var(--color-gold));
  margin-bottom: 2.5rem;
}
.statement__quote {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 700;
  color: #fff;
  line-height: var(--lh-tight);
  letter-spacing: var(--ls-tighter);
  display: flex;
  flex-direction: column;
  gap: .15em;
  margin-bottom: 3rem;
}
.statement__line { overflow: hidden; }
.statement__line-inner { display: block; }
.statement__quote em { color: var(--color-gold-light); font-style: italic; }
.statement__meta {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  font-size: .78rem;
  font-weight: 600;
  letter-spacing: var(--ls-wider);
  text-transform: uppercase;
  color: rgba(255,255,255,.35);
}
.statement__meta-sep {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--color-gold);
  opacity: .5;
  flex-shrink: 0;
}

/* Bottom ticker */
.statement__ticker {
  position: relative;
  overflow: hidden;
  margin-top: clamp(4rem, 8vh, 6rem);
  padding-block: 1.25rem;
  border-top: 1px solid rgba(255,255,255,.06);
  -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
  mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%);
}
.statement__ticker-inner {
  display: flex;
  white-space: nowrap;
  gap: 2.5rem;
  will-change: transform;
}
.statement__ticker-inner span {
  display: inline-flex;
  align-items: center;
  gap: .75rem;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: var(--ls-wider);
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
  flex-shrink: 0;
}
.marquee__dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--color-gold);
  flex-shrink: 0;
  opacity: .5;
}
@media (max-width: 640px) {
  .statement__meta { flex-direction: column; gap: .75rem; }
  .statement__meta-sep { width: 1.5rem; height: 1.5px; border-radius: 1px; }
}
</style>
