---
---

<button
  data-theme-toggle
  class="theme-toggle"
  aria-label="Cambia tema chiaro/scuro"
  aria-pressed="false"
  title="Tema"
>
  <!-- Sun icon (visible in dark mode) -->
  <svg class="theme-toggle__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon (visible in light mode) -->
  <svg class="theme-toggle__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
  </svg>
</button>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  if (btn) {
    /* Sync initial aria-pressed state */
    btn.setAttribute('aria-pressed', String(document.documentElement.classList.contains('dark')));

    /* Update aria-pressed after theme change */
    document.addEventListener('theme:change', (e: Event) => {
      const { dark } = (e as CustomEvent<{ dark: boolean }>).detail;
      btn.setAttribute('aria-pressed', String(dark));
    });
  }
</script>

<style>
.theme-toggle {
  width: 38px;
  height: 38px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-secondary);
  background: transparent;
  border: 1.5px solid transparent;
  box-shadow: inset 0 0 0 1.5px var(--color-border-ui);
  transition:
    color var(--duration-200),
    box-shadow var(--duration-200),
    background var(--duration-200);
  cursor: pointer;
  flex-shrink: 0;
}
.theme-toggle:hover {
  color: var(--color-gold);
  box-shadow: inset 0 0 0 1.5px var(--color-gold);
  background: var(--color-gold-pale);
}
.dark .theme-toggle:hover { background: rgba(196,146,42,.12); }
.theme-toggle:focus-visible { outline: 3px solid var(--color-gold); outline-offset: 2px; }

/* In light mode: mostra luna, nascondi sole */
.theme-toggle__sun  { display: none; }
.theme-toggle__moon { display: block; }

/* In dark mode: mostra sole, nascondi luna */
.dark .theme-toggle__sun  { display: block; }
.dark .theme-toggle__moon { display: none; }
</style>
